{
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(python -c \"import ast; [ast.parse\\(open\\(f, encoding=''utf-8''\\).read\\(\\)\\) for f in [''extension_manager.py'', ''core_handlers.py'', ''commands.py'', ''router.py'']]; print\\(''All syntax OK''\\)\")",
      "Bash(ls -1t .claude/handoffs/*.md)",
      "Bash(uv run:*)",
      "Bash(git add:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "shadcn",
    "chrome-devtools"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR/.claude/scripts\" && uv run python \"$CLAUDE_PROJECT_DIR/.claude/hooks/prp-confidence-check.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR/.claude/scripts\" && uv run python \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-compact-flush.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "prompt_input_exit|clear|other",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR/.claude/scripts\" && uv run python \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-end-flush.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR/.claude/scripts\" && uv run python \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start-context.py\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
